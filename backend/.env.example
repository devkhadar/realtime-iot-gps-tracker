# ─────────────────────────────────────────────────────────
# IoT GPS Telemetry Pipeline — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# Server
APP_PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/iot_tracker
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iot_tracker
DB_USER=user
DB_PASSWORD=password

# MQTT Broker
MQTT_BROKER_URL=mqtt://localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_POOL_SIZE=3

# MQTT Topics — one per geofence zone (rename to match your site)
MQTT_TOPIC_ZONE_A=locator/zone-alpha
MQTT_TOPIC_ZONE_B=locator/zone-beta

# Pipeline Tuning
DEVICE_OFFLINE_THRESHOLD_MS=60000
DEVICE_RATE_LIMIT_PER_SEC=10

# Redis Cache
REDIS_URL=redis://localhost:6379

# External Fleet API (optional — pull vehicle data from a 3rd-party fleet provider)
EXTERNAL_FLEET_API_URL=https://api.your-fleet-provider.com
EXTERNAL_FLEET_API_USERNAME=admin
EXTERNAL_FLEET_API_PASSWORD=password
EXTERNAL_FLEET_API_KEY=your_api_key_here
EXTERNAL_FLEET_API_BASIC_AUTH_TOKEN=

# Security
JWT_SECRET=change_me_to_a_long_random_string
WEBHOOK_SECRET=change_me_to_a_long_random_string

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ENABLE_CORS=true

# Swagger
SWAGGER_ONLY_LIVE=false

# Mocking for Local Development (Run `npm run dev:mock` to enable)
# USE_MOCK_REDIS=true
# USE_MOCK_DB=true
# USE_MOCK_MQTT=true

# NOTE: Duty/schedule settings (working hours, days) are managed through the
# Admin UI and persisted in the database (SystemSettings table). No env vars needed.
